async function saveProfileUpdates(upd){return new Promise(res=>{const u=DB.updateUser(currentUser.id,upd);if(u){currentUser=u;localStorage.setItem('current_user',JSON.stringify(u));updateUserInfo();closeProfileModal();toast('Perfil atualizado!');res(true);}else{toast('Erro ao atualizar!','error');res(false);}});}

function limparTudo(){if(confirm('ATENÇÃO: Apagar demandas, equipes, ruas e bairros? (Agentes serão mantidos)')){localStorage.removeItem('demandas_db');localStorage.removeItem('streets_db');localStorage.removeItem('neighborhoods_db');localStorage.removeItem('equipes_db');toast('Dados apagados! (Agentes mantidos)','warn');renderDashboard();}}
function exportBackup(){const di=document.getElementById('bk-di').value,df=document.getElementById('bk-df').value;if(!di||!df){toast('Selecione o período!','warn');return;}if(di>df){toast('Data inicial > final!','error');return;}const all=DB.getDemandas(),filt=all.filter(x=>{const d=x.created?x.created.split('T')[0]:(x.data||'');return d>=di&&d<=df;});if(!filt.length){toast('Nenhum registro no período!','warn');return;}const data={system:'Sistema de Gerenciamento Operacional',exportDate:new Date().toISOString(),period:{start:di,end:df},totalRecords:filt.length,demands:filt};const blob=new Blob([JSON.stringify(data,null,2)],{type:'application/json'}),url=URL.createObjectURL(blob),a=document.createElement('a');a.href=url;a.download=`backup_sgo_${di}_a_${df}.json`;document.body.appendChild(a);a.click();document.body.removeChild(a);URL.revokeObjectURL(url);toast(`Backup exportado! (${filt.length} registros)`,'success');}

document.addEventListener('DOMContentLoaded',()=>{try{const saved=localStorage.getItem('current_user');if(saved){currentUser=JSON.parse(saved);showApp();}}catch(e){console.error('Erro ao carregar sessão:',e);}});
</script>
