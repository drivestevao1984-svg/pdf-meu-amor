  document.getElementById('loginPass').value='';
}
function setupUppercaseInputs(){['nd-rua','nd-bairro','nd-ref','nd-obs','nd-numero','at-nome','at-tel','at-rua','at-bairro','at-ref','at-numero','at-desc','user-name','user-login','demand-type-name','profileName','profileRole','ag-nome','ag-matricula','ag-funcao','eq-viatura-nome','eq-viatura-num','eq-smartphone'].forEach(id=>{const el=document.getElementById(id);if(!el)return;el.classList.add('uppercase');el.addEventListener('input',e=>{const s=e.target.selectionStart;e.target.value=e.target.value.toUpperCase();e.target.setSelectionRange(s,s);});el.addEventListener('blur',e=>e.target.value=e.target.value.toUpperCase());});}
