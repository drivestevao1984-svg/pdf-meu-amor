function editarDemanda(id){
  const it=DB.getDemandas().find(x=>x.id===id);
  if(!it){toast('Não encontrada!','error');return;}
  go('nova-demanda');
  editDemandaId=id;
  document.getElementById('nd-tipo').value=it.tipoDemanda||'';
  document.getElementById('nd-data').value=it.data||'';
  document.getElementById('nd-hora').value=it.hora||'';
  document.getElementById('nd-rua').value=it.rua||'';
  document.getElementById('nd-bairro').value=it.bairro||'';
  document.getElementById('nd-numero').value=it.numero||'';
  document.getElementById('nd-ref').value=it.referencia||'';
  document.getElementById('nd-obs').value=it.observacoes||'';
  selectedNdAgents=it.agentes||[];
  window.renderNDTags();
