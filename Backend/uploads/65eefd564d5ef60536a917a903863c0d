// ===== VERIFICAÇÃO DE CONFLITO CORRIGIDA (IGNORA A PRÓPRIA DEMANDA EM EDIÇÃO) =====
function verificarConflitoAgentes(agentsArr, excludeId=null){
  const all=DB.getDemandas();
  const emAndamento=all.filter(x=>x.status==='em_andamento');
  let conflitos=[];
  agentsArr.forEach(a=>{
    emAndamento.forEach(d=>{
      // Ignora se for a mesma demanda que está sendo editada
      if(excludeId && d.id===excludeId) return;
      
      if(d.agentes && d.agentes.includes(a)){
        conflitos.push(`${a} (${d.tipoDemanda})`);
      }
    });
  });
  return [...new Set(conflitos)];
}

function salvarDemanda(){
  const tipo=document.getElementById('nd-tipo').value,data=document.getElementById('nd-data').value,hora=document.getElementById('nd-hora').value;
  const rua=document.getElementById('nd-rua').value.toUpperCase(),bairro=document.getElementById('nd-bairro').value.toUpperCase();
  const num=document.getElementById('nd-numero').value.toUpperCase(),ref=document.getElementById('nd-ref').value.toUpperCase(),obs=document.getElementById('nd-obs').value.toUpperCase();
  if(!tipo){toast('Selecione o tipo de demanda!','warn');return;}
  if(!rua||!bairro){toast('Preencha Rua e Bairro!','warn');return;}
  if(!selectedNdAgents.length){toast('Selecione ao menos um agente!','warn');return;}
  
  // ✅ Verificação de conflito (passa o ID da demanda em edição para ignorá-la)
  const conflitoNd=verificarConflitoAgentes(selectedNdAgents, editDemandaId);
  if(conflitoNd.length>0){
    toast(`⚠️ Agentes indisponíveis: ${conflitoNd.join(', ')}. Finalize as demandas em andamento.`, 'warn');
    return;
  }
  
  DB.addStreet(rua);DB.addNeighborhood(bairro);loadAddressDatalists();
  const item={tipo:'demanda',tipoDemanda:tipo,data,hora,rua,bairro,numero:num,referencia:ref,agentes:[...selectedNdAgents],observacoes:obs,status:'em_andamento',origem:'Formulário',updated:new Date().toISOString()};
  if(editDemandaId){
    const r=DB.updateDemanda(editDemandaId,item);
    if(r) toast(`✅ Demanda #${r.num} ATUALIZADA`);
  }else{
    const r=DB.addDemanda(item);
    toast(`✅ Nova demanda #${r.num}`);
  }
  limparNovaDemanda();updateAllBadges();go('demandas-andamento');
}
