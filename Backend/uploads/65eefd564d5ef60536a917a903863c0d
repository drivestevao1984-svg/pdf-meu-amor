function renderRelAgentes(){const all=DB.getDemandas();const agenteSelecionado=document.getElementById('ra-agente').value.trim();const tipoSelecionado=document.getElementById('ra-tipo').value.trim();const di=document.getElementById('ra-di').value;const df=document.getElementById('ra-df').value;let filtered=all;if(agenteSelecionado){filtered=all.filter(x=>x.agentes&&x.agentes.includes(agenteSelecionado));}if(di)filtered=filtered.filter(x=>x.data>=di);if(df)filtered=filtered.filter(x=>x.data<=df);if(tipoSelecionado)filtered=filtered.filter(x=>x.tipoDemanda===tipoSelecionado);const total=filtered.length;const done=filtered.filter(x=>x.status==='finalizada').length;const pending=total-done;const rate=total?Math.round(done/total*100):0;document.getElementById('ra-summary').innerHTML=`<div class="stat-card"><div class="stat-icon blue"><i class="fas fa-list"></i></div><div class="stat-info"><div class="val">${total}</div><div class="label">Total Demandas</div></div></div><div class="stat-card"><div class="stat-icon green"><i class="fas fa-check"></i></div><div class="stat-info"><div class="val">${done}</div><div class="label">Finalizadas</div></div></div><div class="stat-card"><div class="stat-icon orange"><i class="fas fa-hourglass-half"></i></div><div class="stat-info"><div class="val">${pending}</div><div class="label">Pendentes</div></div></div><div class="stat-card"><div class="stat-icon purple"><i class="fas fa-percentage"></i></div><div class="stat-info"><div class="val" style="color:var(--success)">${rate}%</div><div class="label">Taxa de Resolução</div></div></div>`;const counts={};filtered.forEach(x=>{const type=x.tipoDemanda||'Outros';counts[type]=(counts[type]||0)+1;});const tbody=document.getElementById('ra-table');tbody.innerHTML=Object.entries(counts).map(([type,count])=>`<tr><td><b>${type}</b></td><td style="text-align:center;">${count}</td></tr>`).join('')||'<tr><td colspan="2" style="text-align:center;padding:30px;color:#999;">Nenhuma demanda encontrada.<