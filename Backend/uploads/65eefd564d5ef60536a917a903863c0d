function fmtDate(d){if(!d)return'-';const[y,m,dd]=d.split('-');return`${dd}/${m}/${y}`;}

function getDistinctColor(index,total){const hue=(index*360/total)%360;return`hsl(${hue}, 70%, 50%)`;}
function renderDonutChart(containerId,segments,total){const container=document.getElementById(containerId);if(!segments.length||total===0){container.innerHTML='<p style="color:#999;font-size:11px;text-align:center;padding:20px;">Sem dados para exibir</p>';return;}const radius=50,stroke=20,circumference=2*Math.PI*radius;let offset=0;const svg=segments.map((seg,i)=>{const pct=(seg.value/total)*100;const dash=(pct/100)*circumference;const color=getDistinctColor(i,segments.length);const circle=`<circle cx="80" cy="80" r="${radius}" fill="none" stroke="${color}" stroke-width="${stroke}" stroke-dasharray="${dash} ${circumference - dash}" stroke-dashoffset="${-offset}" stroke-linecap="round"/>`;offset+=dash;return circle;}).join('');const legend=segments.map((seg,i)=>`<div class="legend-item"><div class="legend-dot" style="background:${getDistinctColor(i,segments.length)}"></div><span>${seg.label}: <b>${seg.value}</b></span></div>`).join('');container.innerHTML=`<div class="donut-wrapper"><div class="donut-chart"><svg class="donut-svg" width="160" height="160" viewBox="0 0 160 160"><circle cx="80" cy="80" r="${radius}" fill="none" stroke="#e2e8f0" stroke-width="${stroke}"/>${svg}</svg><div class="donut-center"><div class="val">${total}</div><div class="label">Total</div></div></div><div class="donut-legend">${legend}</div></div>`;}
function renderBarChart(containerId,data,maxValue){const container=document.getElementById(containerId);if(!data.length){container.innerHTML='<p style="color:#999;font-size:11px;text-align:center;padding:20px;">Sem dados para exibir</p>';return;}const max=maxValue||Math.max(...data.map(d=>d.value),1);container.innerHTML=`<div class="chart-bars">${data.map((d,i)=>{const pct=Math.round((d.value/max)*100);const color=getDistinctColor(i,data.length);return`<div class="chart-bar-item"><div class="chart-bar-label" title="${d.label}">${d.label}</div><div class="chart-bar-track"><div class="chart-bar-fill" style="width:${pct}%; background:${color};"><span class="chart-bar-value">${d.value}</span></div></div></div>`;}).join('')}</div>`;}

