to</td></tr>';document.getElementById('rt-info').textContent=`Mostrando ${pageData.length} de ${filtered.length} registros`;let pagHtml=`<button class="btn btn-sm btn-outline" ${rtPage===1?'disabled':''} onclick="rtPage--;renderRelTelefonico()"><i class="fas fa-chevron-left"></i></button>`;for(let i=1;i<=Math.min(totalPages,10);i++){pagHtml+=`<button class="btn btn-sm ${i===rtPage?'btn-primary':'btn-outline'}" onclick="rtPage=${i};renderRelTelefonico()">${i}</button>`;}pagHtml+=`<button class="btn btn-sm btn-outline" ${rtPage>=totalPages||totalPages===0?'disabled':''} onclick="rtPage++;renderRelTelefonico()"><i class="fas fa-chevron-right"></i></button>`;document.getElementById('rt-pag').innerHTML=pagHtml;}

