function togglePassword(){const p=document.getElementById('loginPass'),e=document.getElementById('eyeIcon');if(p.type==='password'){p.type='text';e.classList.replace('fa-eye','fa-eye-slash');}else{p.type='password';e.classList.replace('fa-eye-slash','fa-eye');}}
function handleLogoUpload(e){const f=e.target.files[0];if(!f||!f.type.startsWith('image/')||f.size>5*1024*1024){toast('Imagem inválida!','error');return;}const r=new FileReader();r.onload=ev=>{document.getElementById('loginLogo').src=ev.target.result;document.getElementById('headerLogo').src=ev.target.result;localStorage.setItem('institution_logo',ev.target.result);toast('Logo atualizado!','success');};r.readAsDataURL(f);}
function compressImage(file,maxWidth=150,maxHeight=150,quality=0.7){return new Promise((res,rej)=>{const reader=new FileReader();reader.readAsDataURL(file);reader.onload=e=>{const img=new Image();img.src=e.target.result;img.onload=()=>{let w=img.width,h=img.height;if(w>h){if(w>maxWidth){h=Math.round(h*maxWidth/w);w=maxWidth;}}else{if(h>maxHeight){w=Math.round(w*maxHeight/h);h=maxHeight;}}const c=document.createElement('canvas');c.width=w;c.height=h;c.getContext('2d').drawImage(img,0,0,w,h);res(c.toDataURL('image/jpeg',quality));};img.onerror=rej;};reader.onerror=rej;});}

const DB={
  get:k=>{try{const d=localStorage.getItem(k);return d?JSON.parse(d):[];}catch(e){return[];}},
  set:(k,v)=>{try{localStorage.setItem(k,JSON.stringify(v));}catch(e){console.error('Erro ao salvar:',e);}},
  getDemandas:()=>DB.get('demandas_db'),setDemandas:d=>DB.set('demandas_db',d),
  addDemanda:item=>{const d=DB.getDemandas();item.id=d.length?Math.max(...d.map(x=>x.id))+1:1;const s=d.filter(x=>x.tipo===item.tipo),m=s.reduce((a,x)=>Math.max(a,parseInt(x.num)||0),0);item.num=String(m+1).padStart(3,'0');item.created=new Date().toISOString();d.push(item);DB.setDemandas(d);return item;},
  updateDemanda:(id,data)=>{const a=DB.getDemandas(),i=a.findIndex(x=>x.id===id);if(i>-1){a[i]={...a[i],...data,updated:new Date().toISOString()};DB.setDemandas(a);return a[i];}return null;},
  getUsers:()=>{
    const u=DB.get('users_db');
    if(!u.length){
      const d=[
        {id:1,name:'Administrador',login:'admin',pass:'admin123',role:'admin',active:true,photo:null,cargo:'Administrador'},
        {id:2,name:'Operador',login:'operador',pass:'op123',role:'operator',active:true,photo:null,cargo:'Operador'},
        {id:3,name:'Analista',login:'analista',pass:'ana123',role:'analyst',active:true,photo:null,cargo:'Analista'}
      ];
      DB.set('users_db', d); return d;
    }
    return u;
  },
  setUsers:u=>DB.set('users_db',u),
  addUser:user=>{const u=DB.getUsers();user.id=u.length?Math.max(...u.map(x=>x.id))+1:1;user.active=true;user.photo=null;user.cargo=user.cargo||'';u.push(user);DB.setUsers(u);return user;},
  updateUser:(id,data)=>{const u=DB.getUsers(),i=u.findIndex(x=>x.id===id);if(i>-1){u[i]={...u[i],...data};DB.setUsers(u);return u[i];}return null;},
  deleteUser:id=>DB.setUsers(DB.getUsers().filter(u=>u.id!==id)),
  getDemandTypes:()=>{const t=DB.get('demand_types');if(!t.length){const d=['Apoio Operacional','Fiscalização de Trânsito','Manutenção','Ocorrência Diversa','Patrulhamento Escolar'];DB.set('demand_types',d);return d.sort();}return t;},
  setDemandTypes:t=>DB.set('demand_types',t),
  addDemandType:name=>{const t=DB.getDemandTypes();if(!t.includes(name)){t.push(name);DB.setDemandTypes(t);}return t;},
  updateDemandType:(old,neu)=>{const t=DB.getDemandTypes(),i=t.indexOf(old);if(i>-1){t[i]=neu;DB.setDemandTypes(t);}return t;},
  deleteDemandType:name=>DB.setDemandTypes(DB.getDemandTypes().filter(t=>t!==name)),
  getAgents:()=>DB.get('agents_db'),setAgents:a=>DB.set('agents_db',a),
  addAgent:agent=>{const a=DB.getAgents();agent.id=a.length?Math.max(...a.map(x=>x.id))+1:1;agent.ativo=true;a.push(agent);DB.setAgents(a);return agent;},
  updateAgent:(id,data)=>{const a=DB.getAgents(),i=a.findIndex(x=>x.id===id);if(i>-1){a[i]={...a[i],...data};DB.setAgents(a);return a[i];}return null;},
  deleteAgent:id=>DB.setAgents(DB.getAgents().filter(a=>a.id!==id)),
  getStreets:()=>DB.get('streets_db'),
  addStreet:s=>{if(!s)return;const l=DB.getStreets(),c=s.toUpperCase().trim();if(!l.includes(c)){l.push(c);DB.set('streets_db',l);}},
  getNeighborhoods:()=>DB.get('neighborhoods_db'),
  addNeighborhood:n=>{if(!n)return;const l=DB.getNeighborhoods(),c=n.toUpperCase().trim();if(!l.includes(c)){l.push(c);DB.set('neighborhoods_db',l);}},
  getEquipes:()=>DB.get('equipes_db'),setEquipes:e=>DB.set('equipes_db',e),
  addEquipe:eq=>{const e=DB.getEquipes();eq.id=e.length?Math.max(...e.map(x=>x.id))+1:1;e.push(eq);DB.setEquipes(e);return eq;},
  updateEquipe:(id,data)=>{const e=DB.getEquipes(),i=e.findIndex(x=>x.id===id);if(i>-1){e[i]={...e[i],...data};DB.setEquipes(e);return e[i];}return null;}
};

function setupAgentAutocomplete(prefix){
  const input=document.getElementById(`${prefix}-agente-input`),list=document.getElementById(`${prefix}-agente-list`),container=document.getElementById(`${prefix}-selected-agents`);
  function renderTags(){
    let arr;if(prefix==='nd')arr=selectedNdAgents;else if(prefix==='at')arr=selectedAtAgents;else if(prefix==='eq')arr=selectedEqAgents;
    container.innerHTML=arr.map(name=>`<span class="tag">${name} <span class="tag-rm" onclick="removeAgentTag('${prefix}','${name}')">&times;</span></span>`).join('');
    if(prefix==='eq')renderEqFuncoes();
  }
  window.removeAgentTag=(p,name)=>{if(p==='nd'){selectedNdAgents=selectedNdAgents.filter(n=>n!==name);window.renderNDTags();}else if(p==='at'){selectedAtAgents=selectedAtAgents.filter(n=>n!==name);window.renderATTags();}else if(p==='eq'){selectedEqAgents=selectedEqAgents.filter(n=>n!==name);window.renderEQTags();}};
  input.addEventListener('input',function(){const val=this.value.trim().toUpperCase();if(!val){list.style.display='none';return;}const agents=DB.getAgents().filter(a=>a.ativo&&a.nome.toUpperCase().includes(val));list.innerHTML=agents.map(a=>`<div data-nome="${a.nome}"><b>${a.nome}</b> <small>(Mat: ${a.matricula})</small></div>`).join('');list.style.display=agents.length?'block':'none';});
  list.addEventListener('click',function(e){const item=e.target.closest('div');if(!item)return;const nome=item.dataset.nome;let arr;if(prefix==='nd')arr=selectedNdAgents;else if(prefix==='at')arr=selectedAtAgents;else if(prefix==='eq')arr=selectedEqAgents;if(!arr.includes(nome)){arr.push(nome);renderTags();}input.value='';list.style.display='none';input.focus();});
  document.addEventListener('click',e=>{if(!container.contains(e.target)&&e.target!==input&&!list.contains(e.target))list.style.display='none';});
  window[`render${prefix.toUpperCase()}Tags`]=renderTags;renderTags();
}
function renderEqFuncoes(){const c=document.getElementById('eq-funcoes-container'),l=document.getElementById('eq-funcoes-list');if(!selectedEqAgents.length){c.style.display='none';return;}c.style.display='block';l.innerHTML=selectedEqAgents.map(n=>`<div class="form-row" style="margin-bottom:5px;"><div class="fg" style="flex:1;"><label class="fl">${n}</label><input type="text" class="fc" id="eq-func-${n.replace(/\s/g,'')}" placeholder="Ex: Motorista, Piloto..."></div></div>`).join('');}
function getEqFuncoesData(){let f={};selectedEqAgents.forEach(n=>{const el=document.getElementById(`eq-func-${n.replace(/\s/g,'')}`);f[n]=el?el.value:'';});return f;}

function fillLogin(u,p){document.getElementById('loginUser').value=u;document.getElementById('loginPass').value=p;}
function doLogin(e){
  e.preventDefault();
  try{
    const login=document.getElementById('loginUser').value.trim(),pass=document.getElementById('loginPass').value;
    if(!login||!pass){toast('Preencha usuário e senha!','warn');return;}
    const users=DB.getUsers();
    const user=users.find(u=>u.login===login&&u.pass===pass&&u.active!==false);
    if(user){
      currentUser=user;
      localStorage.setItem('current_user',JSON.stringify(user));
      toast('Login realizado!','success');
      setTimeout(showApp,300);
    }else{
      toast('Usuário ou senha inválidos!','error');
    }
  }catch(err){
    toast('Erro ao fazer login: '+err.message,'error');
  }
}
