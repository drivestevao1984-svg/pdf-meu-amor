function renderRelEnderecos(){
  const all=DB.getDemandas();
  let filtered=all;
  const endFilter=document.getElementById('re-end').value;
  const di=document.getElementById('re-di').value;
  const df=document.getElementById('re-df').value;
  filtered=filtered.filter(x=>{let include=true;if(endFilter&&(x.rua+' - '+x.bairro).trim()!==endFilter)include=false;if(di&&x.data<di)include=false;if(df&&x.data>df)include=false;return include;});

  const groupedByAddress={};
  filtered.forEach(x=>{
    const addr=`${x.rua||'Sem rua'} - ${x.bairro||'Sem bairro'}`.trim();
    const type=x.tipoDemanda||'Outros';
    const teamKey=(x.agentes||[]).sort().join(', ');
    const groupKey=`${type}|||${teamKey}`;
    if(!groupedByAddress[addr]){groupedByAddress[addr]={};}
    if(!groupedByAddress[addr][groupKey]){groupedByAddress[addr][groupKey]={type:type,team:teamKey,dates:[],count:0};}
    groupedByAddress[addr][groupKey].count++;
    groupedByAddress[addr][groupKey].dates.push(x.data);
  });

  const tbody=document.getElementById('re-address-table');
  if(Object.keys(groupedByAddress).length===0){
    tbody.innerHTML='<tr><td colspan="3" style="text-align:center;padding:30px;color:#999;">Nenhuma demanda encontrada.</td></tr>';
  }else{
    let html='';
    Object.entries(groupedByAddress).sort((a,b)=>a[0].localeCompare(b[0])).forEach(([addr,groups])=>{
      const totalEmpenhos=Object.values(groups).reduce((sum,g)=>sum+g.count,0);
      const typesCount={};
      Object.values(groups).forEach(g=>{if(!typesCount[g.type])typesCount[g.type]=0;typesCount[g.type]+=g.count;});
      html+=`<tr>
        <td style="vertical-align:top;padding:12px;border-bottom:1px solid #e2e8f0;">
          <div style="font-weight:700;font-size:13px;margin-bottom:8px;color:var(--primary);">${addr}</div>
          ${Object.values(groups).map(g=>{
            const dateSorted=g.dates.sort()[0];
            return`<div style="font-size:11px;color:#666;margin:4px 0;padding:2px 0;">
              <i class="far fa-calendar-alt" style="color:#f59e0b;margin-right:4px;"></i>
              ${fmtDate(dateSorted)} • ${g.team} <span style="color:var(--accent);font-weight:600;">(x${g.count} ${g.type.toUpperCase()})</span>
            </div>`;
          }).join('')}
        </td>
        <td style="vertical-align:top;padding:12px;border-bottom:1px solid #e2e8f0;">
          ${Object.entries(typesCount).map(([type,count])=>`<span style="display:inline-block;background:#dbeafe;color:#1e40af;padding:4px 10px;border-radius:12px;font-size:11px;font-weight:600;margin:2px;">${type.toUpperCase()}: ${count}</span>`).join('<br>')}
        </td>
        <td style="vertical-align:middle;text-align:center;padding:12px;border-bottom:1px solid #e2e8f0;">
          <span style="display:inline-block;background:#dcfce7;color:#166534;padding:6px 12px;border-radius:8px;font-size:11px;font-weight:700;">${totalEmpenhos} empenho${totalEmpenhos>1?'s':''}</span>
        </td>
      </tr>`;
    });
    tbody.innerHTML=html;
  }
}

