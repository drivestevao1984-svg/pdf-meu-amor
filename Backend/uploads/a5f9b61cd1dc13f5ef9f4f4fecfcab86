function handleLogoUpload(event) {
  const file = event.target.files[0];
  if (!file) return;
  if (!file.type.startsWith('image/')) { toast('Selecione uma imagem válida!', 'error'); return; }
  if (file.size > 5 * 1024 * 1024) { toast('Imagem muito grande. Máximo 5MB.', 'error'); return; }
  const reader = new FileReader();
  reader.onload = function(e) {
    const imageData = e.target.result;
    document.getElementById('loginLogo').src = imageData;
    document.getElementById('headerLogo').src = imageData;
    localStorage.setItem('institution_logo', imageData);
    toast('Logo atualizado com sucesso!', 'success');
  };
  reader.readAsDataURL(file);
}

