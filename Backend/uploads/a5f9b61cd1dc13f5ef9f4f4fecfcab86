  const all = DB.getDemandas();
  const demandas = all.filter(x => x.tipo === 'demanda');
  const telefonicos = all.filter(x => x.tipo === 'telefonico');
  
  document.getElementById('d-total').textContent = demandas.length;
  document.getElementById('d-done').textContent = demandas.filter(x => x.status === 'finalizada').length;
  document.getElementById('d-pending').textContent = demandas.filter(x => x.status === 'em_andamento').length;
  
  document.getElementById('t-total').textContent = telefonicos.length;
  document.getElementById('t-done').textContent = telefonicos.filter(x => x.status === 'finalizada').length;
  document.getElementById('t-pending').textContent = telefonicos.filter(x => x.status === 'aguardando' || x.status === 'em_andamento').length;
  
  updateAllBadges();
}

// ===== GRÁFICOS INTERATIVOS =====
function renderBarChart(containerId, data, colors, maxVal) {
  const container = document.getElementById(containerId);
  if (!data.length) { container.innerHTML = '<p style="color:#999;font-size:12px;text-align:center;padding:20px;">Sem dados para exibir</p>'; return; }
  const max = maxVal || Math.max(...data.map(d => d.value), 1);
  container.innerHTML = data.map((d, i) => `
    <div class="chart-bar-row" style="animation:fadeInUp 0.5s ease ${i*0.1}s both;">
      <div class="chart-bar-label" title="${d.label}">${d.label}</div>
      <div class="chart-bar-track">
        <div class="chart-bar-fill" style="width:0%;background:${colors[i % colors.length]};transition:width 1s ease ${i*0.15}s;" data-width="${(d.value/max)*100}%">
          <span class="chart-bar-value">${d.value}</span>
        </div>
      </div>
    </div>
  `).join('');
  setTimeout(() => {
    container.querySelectorAll('.chart-bar-fill').forEach(bar => { bar.style.width = bar.dataset.width; });
  }, 100);
}

function renderDonutChart(containerId, percent, color, label) {
  const container = document.getElementById(containerId);
  const radius = 70, stroke = 20, circumference = 2 * Math.PI * radius;
  const offset = circumference - (percent / 100) * circumference;
  container.innerHTML = `
    <div class="donut-chart">
      <svg class="donut-svg" width="160" height="160" viewBox="0 0 160 160">
        <circle cx="80" cy="80" r="${radius}" fill="none" stroke="#e5e7eb" stroke-width="${stroke}"/>
        <circle cx="80" cy="80" r="${radius}" fill="none" stroke="${color}" stroke-width="${stroke}" stroke-dasharray="${circumference}" stroke-dashoffset="${circumference}" stroke-linecap="round" style="transition:stroke-dashoffset 1.5s ease;" data-offset="${offset}"/>
      </svg>
      <div class="donut-center">
        <div class="donut-val">${percent}%</div>
        <div class="donut-label">${label}</div>
      </div>
    </div>
  `;
  setTimeout(() => {
    container.querySelector('.donut-svg circle:last-child').style.strokeDashoffset = offset;
  }, 100);
}

// ===== RELATÓRIOS =====
function initRelAgentes() {
  const agents = [...new Set(DB.getDemandas().flatMap(x => x.agentes || []))];
  document.getElementById('ra-agente').innerHTML = '<option value="">Todos</option>' + agents.map(a => `<option>${a}</option>`).join('');
  loadDemandTypes(); renderRelAgentes();
}

function renderRelAgentes() {
  const all = DB.getDemandas(); let filtered = all;
  const agente = document.getElementById('ra-agente').value, tipo = document.getElementById('ra-tipo').value, di = document.getElementById('ra-di').value, df = document.getElementById('ra-df').value;
  if (agente) filtered = filtered.filter(x => (x.agentes || []).includes(agente));
  if (tipo) filtered = filtered.filter(x => x.tipoDemanda === tipo);
  if (di) filtered = filtered.filter(x => x.data >= di);
  if (df) filtered = filtered.filter(x => x.data <= df);
  
  const total = filtered.length, done = filtered.filter(x => x.status === 'finalizada').length, rate = total ? Math.round(done/total*100) : 0;
  document.getElementById('ra-summary').innerHTML = `
    <div class="stat-card"><div class="stat-icon blue"><i class="fas fa-list"></i></div><div class="stat-info"><div class="val">${total}</div><div class="label">Total</div></div></div>
    <div class="stat-card"><div class="stat-icon green"><i class="fas fa-check"></i></div><div class="stat-info"><div class="val">${done}</div><div class="label">Finalizados</div></div></div>
    <div class="stat-card"><div class="stat-icon orange"><i class="fas fa-hourglass-half"></i></div><div class="stat-info"><div class="val">${total-done}</div><div class="label">Pendentes</div></div></div>
    <div class="stat-card"><div class="stat-icon purple"><i class="fas fa-percentage"></i></div><div class="stat-info"><div class="val" style="color:var(--success)">${rate}%</div><div class="label">Resolução</div></div></div>
  `;
  
  const typeCounts = {}; filtered.forEach(x => { typeCounts[x.tipoDemanda] = (typeCounts[x.tipoDemanda] || 0) + 1; });
  const typeData = Object.entries(typeCounts).map(([label, value]) => ({ label, value }));
  renderBarChart('ra-chart-type', typeData, ['#667eea','#764ba2','#11998e','#38ef7d','#f7971e','#ffd200','#eb3349','#f45c43']);
  
  renderDonutChart('ra-chart-rate', rate, '#11998e', 'Taxa de Resolução');
  
  const agentData = {};
  filtered.forEach(x => { (x.agentes || []).forEach(a => {
    if (!agentData[a]) agentData[a] = { total:0, fis:0, apo:0, pat:0, oco:0, done:0 };
    agentData[a].total++;
    if (x.tipoDemanda === 'Fiscalização de Trânsito') agentData[a].fis++;
    if (x.tipoDemanda === 'Apoio Operacional') agentData[a].apo++;
    if (x.tipoDemanda === 'Patrulhamento Escolar') agentData[a].pat++;
    if (x.tipoDemanda === 'Ocorrência Diversa') agentData[a].oco++;
    if (x.status === 'finalizada') agentData[a].done++;
  }); });
  document.getElementById('ra-table').innerHTML = Object.entries(agentData).filter(([k,v]) => v.total > 0).map(([k,v]) => `<tr><td><b>${k}</b></td><td>${v.total}</td><td>${v.fis}</td><td>${v.apo}</td><td>${v.pat}</td><td>${v.oco}</td><td><span style="color:${v.total ? (Math.round(v.done/v.total*100) >= 70 ? 'var(--success)' : 'var(--warning)') : '#999'}"><b>${v.total ? Math.round(v.done/v.total*100) : 0}%</b></span></td></tr>`).join('') || '<tr><td colspan="7" style="text-align:center;padding:20px;color:#999;">Sem dados</td></tr>';
}

function initRelDemandas() { loadDemandTypes(); renderRelDemandas(); }

function renderRelDemandas() {
  const all = DB.getDemandas();
  const tipo = document.getElementById('rd-tipo').value;
  const di = document.getElementById('rd-di').value;
  const df = document.getElementById('rd-df').value;
  
  const filtered = all.filter(x => {
    let include = false;
    if (x.tipo === 'demanda') include = true;
    if (x.tipo === 'telefonico' && x.status === 'finalizada') include = true;
    if (include && tipo && x.tipoDemanda !== tipo) include = false;
    if (include && di && x.data < di) include = false;
    if (include && df && x.data > df) include = false;
    return include;
  });
  
  const total = filtered.length;
  const doneCount = filtered.filter(x => x.status === 'finalizada').length;
  const pendingCount = total - doneCount;
  const rate = total ? Math.round(doneCount/total*100) : 0;
  
  document.getElementById('rd-summary').innerHTML = `
    <div class="stat-card"><div class="stat-icon blue"><i class="fas fa-file-alt"></i></div><div class="stat-info"><div class="val">${total}</div><div class="label">Total (Demandas + Telef. Finalizados)</div></div></div>
    <div class="stat-card"><div class="stat-icon green"><i class="fas fa-check-circle"></i></div><div class="stat-info"><div class="val">${doneCount}</div><div class="label">Finalizados</div></div></div>
    <div class="stat-card"><div class="stat-icon orange"><i class="fas fa-spinner"></i></div><div class="stat-info"><div class="val">${pendingCount}</div><div class="label">Pendentes</div></div></div>
    <div class="stat-card"><div class="stat-icon purple"><i class="fas fa-chart-line"></i></div><div class="stat-info"><div class="val" style="color:var(--success)">${rate}%</div><div class="label">Resolução</div></div></div>
  `;
  
  const typeCounts = {};
  const typeDetail = {};
  
  filtered.forEach(x => {
    const tipoDem = x.tipoDemanda || 'Outros';
    if (!typeCounts[tipoDem]) typeCounts[tipoDem] = 0;
    if (!typeDetail[tipoDem]) typeDetail[tipoDem] = { demanda: 0, telefonico: 0, total: 0 };
    
    typeCounts[tipoDem]++;
    typeDetail[tipoDem].total++;
    if (x.tipo === 'demanda') typeDetail[tipoDem].demanda++;
    else if (x.tipo === 'telefonico') typeDetail[tipoDem].telefonico++;
  });
  
  const typeEntries = Object.entries(typeDetail).sort((a,b) => b[1].total - a[1].total);
  document.getElementById('rd-type-count').innerHTML = typeEntries.length ? typeEntries.map(([tipo, d], i) => {
    const pct = total ? Math.round(d.total/total*100) : 0;
    return `<tr>
      <td><b>${i+1}. ${tipo}</b></td>
      <td style="text-align:center;"><b>${d.total}</b></td>
      <td style="text-align:center;">${d.demanda}</td>
      <td style="text-align:center;">${d.telefonico}</td>
      <td style="text-align:center;"><span class="badge badge-active">${pct}%</span></td>
    </tr>`;
  }).join('') : '<tr><td colspan="5" style="text-align:center;padding:20px;color:#999;">Sem dados para exibir</td></tr>';
  
  const agC = {}; filtered.forEach(x => (x.agentes || []).forEach(a => agC[a] = (agC[a] || 0) + 1));
  const topAg = Object.entries(agC).sort((a,b) => b[1]-a[1]).slice(0,5);
  renderBarChart('rd-chart-agents', topAg.map(([label, value]) => ({ label, value })), ['#667eea','#764ba2','#11998e','#f7971e','#eb3349']);
  
  const enC = {}; filtered.forEach(x => { const e = `${x.rua||''} - ${x.bairro||''}`.trim(); if (e) enC[e] = (enC[e] || 0) + 1; });
  const topEn = Object.entries(enC).sort((a,b) => b[1]-a[1]).slice(0,5);
  renderBarChart('rd-chart-end', topEn.map(([label, value]) => ({ label, value })), ['#00c6ff','#0072ff','#7f00ff','#e100ff','#f7971e']);

  const addrCount = {};
  filtered.forEach(x => {
    const addr = (x.rua || '') + ' - ' + (x.bairro || '');
    if (addr.trim()) addrCount[addr] = (addrCount[addr] || 0) + 1;
  });
  const sortedAddr = Object.entries(addrCount).sort((a, b) => b[1] - a[1]);
  
  document.getElementById('rd-address-rank').innerHTML = sortedAddr.length ? sortedAddr.map((entry, i) => {
    const pct = total ? Math.round((entry[1] / total) * 100) : 0;
    return `<tr>
      <td style="text-align:center;">${i+1}</td>
      <td><b>${entry[0]}</b></td>
      <td style="text-align:center;"><b style="font-size:14px;">${entry[1]}</b></td>
      <td style="text-align:center;"><span class="badge badge-active">${pct}%</span></td>
    </tr>`;
  }).join('') : '<tr><td colspan="4" style="text-align:center;padding:20px;color:#999;">Sem dados para exibir</td></tr>';
}

function initRelEnderecos() {
  const addrs = [...new Set(DB.getDemandas().map(x => `${x.rua||''} - ${x.bairro||''}`.trim()).filter(e => e))];
  document.getElementById('re-end').innerHTML = '<option value="">Todos</option>' + addrs.map(a => `<option>${a}</option>`).join('');
  renderRelEnderecos();
}

function renderRelEnderecos() {
  const all = DB.getDemandas(); 
  let filtered = all;
  
  const endFilter = document.getElementById('re-end').value;
  const di = document.getElementById('re-di').value;
  const df = document.getElementById('re-df').value;
  
  filtered = filtered.filter(x => {
    let include = true;
    if (endFilter && (x.rua + ' - ' + x.bairro).trim() !== endFilter) include = false;
    if (di && x.data < di) include = false;
    if (df && x.data > df) include = false;
    return include;
  });

  const addressSummary = {};
  filtered.forEach(x => {
    const key = (x.rua || '') + ' - ' + (x.bairro || '');
    if (!addressSummary[key]) {
      addressSummary[key] = { total: 0, fis: 0, apo: 0, pat: 0, oco: 0, done: 0 };
    }
    addressSummary[key].total++;
    if (x.tipoDemanda === 'Fiscalização de Trânsito') addressSummary[key].fis++;
    else if (x.tipoDemanda === 'Apoio Operacional') addressSummary[key].apo++;
    else if (x.tipoDemanda === 'Patrulhamento Escolar') addressSummary[key].pat++;
    else addressSummary[key].oco++;
    if (x.status === 'finalizada') addressSummary[key].done++;
  });
  
  const sortedAddresses = Object.entries(addressSummary).sort((a, b) => b[1].total - a[1].total);
  document.getElementById('re-address-table').innerHTML = sortedAddresses.length ? sortedAddresses.map(([addr, data]) => `
    <tr>
      <td><b>${addr}</b></td>
      <td style="text-align:center;"><b style="font-size:14px;">${data.total}</b></td>
      <td style="text-align:center;">${data.fis}</td>
      <td style="text-align:center;">${data.apo}</td>
      <td style="text-align:center;">${data.pat}</td>
      <td style="text-align:center;">${data.oco}</td>
    </tr>
  `).join('') : '<tr><td colspan="6" style="text-align:center;padding:20px;color:#999;">Nenhum endereço encontrado</td></tr>';
  
  const total = filtered.length;
  const done = filtered.filter(x => x.status === 'finalizada').length;
  
  document.getElementById('re-summary').innerHTML = `
    <div class="stat-card"><div class="stat-icon blue"><i class="fas fa-map-marker-alt"></i></div><div class="stat-info"><div class="val">${total}</div><div class="label">Total de Demandas</div></div></div>
    <div class="stat-card"><div class="stat-icon green"><i class="fas fa-check"></i></div><div class="stat-info"><div class="val">${done}</div><div class="label">Finalizados</div></div></div>
    <div class="stat-card"><div class="stat-icon purple"><i class="fas fa-percentage"></i></div><div class="stat-info"><div class="val" style="color:var(--success)">${total ? Math.round(done/total*100) : 0}%</div><div class="label">Resolução</div></div></div>
  `;
  
  const typeC = {}; filtered.forEach(x => { typeC[x.tipoDemanda] = (typeC[x.tipoDemanda] || 0) + 1; });
  renderBarChart('re-chart-type', Object.entries(typeC).map(([label, value]) => ({ label, value })), ['#667eea','#11998e','#f7971e','#eb3349','#7f00ff']);
  
  const agC = {}; filtered.forEach(x => (x.agentes || []).forEach(a => agC[a] = (agC[a] || 0) + 1));
  const topAg = Object.entries(agC).sort((a,b) => b[1]-a[1]).slice(0,6);
  renderBarChart('re-chart-agents', topAg.map(([label, value]) => ({ label, value })), ['#00c6ff','#0072ff','#667eea','#764ba2','#11998e','#f7971e']);
}

function initRelTelefonico() { loadDemandTypes(); renderRelTelefonico(); }

function renderRelTelefonico() {
  rtPage = 1;
  const all = DB.getDemandas().filter(x => x.tipo === 'telefonico'); let filtered = all;
  const origem = document.getElementById('rt-origem').value, tipo = document.getElementById('rt-tipo').value, di = document.getElementById('rt-di').value, df = document.getElementById('rt-df').value;
  if (origem) filtered = filtered.filter(x => x.origem === origem);
  if (tipo) filtered = filtered.filter(x => x.tipoDemanda === tipo);
  if (di) filtered = filtered.filter(x => x.data >= di);
  if (df) filtered = filtered.filter(x => x.data <= df);
  
  const perPage = 10, totalPages = Math.ceil(filtered.length/perPage), pageData = filtered.slice((rtPage-1)*perPage, rtPage*perPage);
  
  document.getElementById('rt-table').innerHTML = pageData.length ? pageData.map(x => {
    const sc = x.status==='finalizada'?'badge-done':x.status==='em_andamento'?'badge-active':'badge-pending';
    const st = x.status==='finalizada'?'Finalizada':x.status==='em_andamento'?'Em atendimento':'Aguardando';
    return `<tr><td>${x.num}</td><td>${x.nome||'-'}</td><td>${x.telefone||'-'}</td><td>${x.tipoDemanda}</td><td>${x.numero ? x.numero + ' - ' : ''}${x.rua||''} ${x.bairro||''}</td><td>${(x.agentes||[]).join(', ')}</td><td>${fmtDate(x.data)}</td><td>${x.hora}</td><td><span class="badge ${sc}">${st}</span></td><td><div class="action-btns"><button class="abtn view" onclick="event.stopPropagation(); verDetalhe(${x.id}, 'telefonico')"><i class="fas fa-eye"></i></button></div></td></tr>`;
  }).join('') : '<tr><td colspan="10" style="text-align:center;padding:30px;color:#999;">Nenhum atendimento</td></tr>';
  
  document.getElementById('rt-info').textContent = `Mostrando ${pageData.length} de ${filtered.length} registros`;
  
  let pagHtml = `<button class="btn btn-sm btn-outline" ${rtPage===1?'disabled':''} onclick="rtPage--;renderRelTelefonico()"><i class="fas fa-chevron-left"></i></button>`;
  for(let i=1;i<=Math.min(totalPages,10);i++){ pagHtml += `<button class="btn btn-sm ${i===rtPage?'btn-primary':'btn-outline'}" onclick="rtPage=${i};renderRelTelefonico()">${i}</button>`; }
  pagHtml += `<button class="btn btn-sm btn-outline" ${rtPage>=totalPages||totalPages===0?'disabled':''} onclick="rtPage++;renderRelTelefonico()"><i class="fas fa-chevron-right"></i></button>`;
  document.getElementById('rt-pag').innerHTML = pagHtml;
}

// ✅ FUNÇÃO DE BACKUP COM SELEÇÃO DE PERÍODO
function exportBackup() {
  const di = document.getElementById('bk-di').value;
  const df = document.getElementById('bk-df').value;
  if (!di || !df) {
    toast('Selecione o período (data inicial e final)!', 'warn');
    return;
  }
  if (di > df) {
    toast('Data inicial não pode ser maior que a data final!', 'error');
    return;
  }
  
  const allData = DB.getDemandas();
  const filtered = allData.filter(x => {
    const itemDate = x.created ? x.created.split('T')[0] : (x.data || '');
    return itemDate >= di && itemDate <= df;
  });
  
  if (filtered.length === 0) {
    toast('Nenhum registro encontrado no período selecionado!', 'warn');
    return;
  }
  
  const backupData = {
    system: 'Sistema de Gerenciamento Operacional',
    exportDate: new Date().toISOString(),
    period: { start: di, end: df },
    totalRecords: filtered.length,
    demands: filtered
  };
  
  const blob = new Blob([JSON.stringify(backupData, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `backup_sgo_${di}_a_${df}.json`;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
  toast(`Backup exportado com sucesso! (${filtered.length} registros)`, 'success');
}

