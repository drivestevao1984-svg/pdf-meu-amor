async function saveProfile() {
  const name = document.getElementById('profileName').value.trim().toUpperCase(), cargo = document.getElementById('profileRole').value.trim().toUpperCase(); const photoInput = document.getElementById('profilePhoto');
  if (!name) { toast('Nome é obrigatório!', 'warn'); return; }
  const updates = { name, cargo };
  if (photoInput.files && photoInput.files[0]) {
    const file = photoInput.files[0];
    if (!file.type.startsWith('image/')) { toast('Selecione uma imagem válida!', 'error'); return; }
    if (file.size > 2 * 1024 * 1024) { toast('Imagem muito grande. Máximo 2MB.', 'error'); return; }
    try { const btn = document.getElementById('btnSaveProfile'); const originalBtnText = btn.innerHTML; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Salvando...'; btn.disabled = true;
      const compressedPhoto = await compressImage(file); updates.photo = compressedPhoto; await saveProfileUpdates(updates);
      btn.innerHTML = originalBtnText; btn.disabled = false;
    } catch (error) { console.error('Erro ao processar imagem:', error); toast('Erro ao processar a imagem. Tente outra.', 'error'); const btn = document.getElementById('btnSaveProfile'); btn.innerHTML = '<i class="fas fa-save"></i> SALVAR'; btn.disabled = false; }
  } else { await saveProfileUpdates(updates); }
}
async function saveProfileUpdates(updates) { return new Promise((resolve) => { const updatedUser = DB.updateUser(currentUser.id, updates); if (updatedUser) { currentUser = updatedUser; localStorage.setItem('current_user', JSON.stringify(currentUser)); updateUserInfo(); closeProfileModal(); toast('Perfil atualizado com sucesso!'); resolve(true); } else { toast('Erro ao atualizar perfil.', 'error'); resolve(false); } }); }

