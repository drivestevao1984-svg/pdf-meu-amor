// ✅ CORREÇÃO: LOGICA DE PERMISSÕES COM 3 NÍVEIS
function updateMenuPermissions() {
  if (!currentUser) return;

  // Normaliza o role para garantir comparação segura
  const role = (currentUser.role || '').trim().toLowerCase();
  const isAdmin = role === 'admin';
  const isAnalyst = role === 'analyst';
  
  const relPages = ['rel-agentes', 'rel-demandas', 'rel-enderecos', 'rel-telefonico'];
  const configPages = ['configuracoes'];
  
  // 1. Atualizar visibilidade dos itens do menu
  document.querySelectorAll('.nav-item').forEach(item => {
    const page = item.dataset.page;
    if (!page) return;

    let shouldShow = false;
    
    // Configurações: Só Admin
    if (configPages.includes(page)) {
        shouldShow = isAdmin;
    } 
    // Relatórios: Admin e Analista
    else if (relPages.includes(page)) {
        shouldShow = isAdmin || isAnalyst;
    } 
    // Menu Principal: Todos
    else {
        shouldShow = true;
    }

    if (shouldShow) {
        item.classList.remove('hidden');
    } else {
        item.classList.add('hidden');
    }

    // 2. Permissão de Clique
    let canClick = false;
    if (configPages.includes(page)) {
        canClick = isAdmin;
    } else if (relPages.includes(page)) {
        canClick = isAdmin || isAnalyst;
    } else {
        canClick = true;
    }

    // Resetar onclick para evitar acúmulo
    item.onclick = null;

    if (canClick) {
        item.classList.remove('disabled');
        item.onclick = (e) => {
             e.preventDefault();
             go(page);
        };
    } else {
        item.classList.add('disabled');
        item.onclick = (e) => {
            e.preventDefault();
            let msg = 'Acesso restrito.';
            if (configPages.includes(page)) msg = 'Apenas Administradores podem acessar as Configurações.';
            else if (relPages.includes(page)) msg = 'Apenas Administradores e Analistas podem acessar os Relatórios.';
            toast(msg, 'warn');
        };
    }
  });
}

