// ===== COMPRESSÃO DE IMAGEM =====
function compressImage(file, maxWidth = 150, maxHeight = 150, quality = 0.7) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader(); reader.readAsDataURL(file);
    reader.onload = (event) => {
      const img = new Image(); img.src = event.target.result;
      img.onload = () => {
        let width = img.width, height = img.height;
        if (width > height) { if (width > maxWidth) { height = Math.round(height * maxWidth / width); width = maxWidth; } }
        else { if (height > maxHeight) { width = Math.round(width * maxHeight / height); height = maxHeight; } }
        const canvas = document.createElement('canvas'); canvas.width = width; canvas.height = height;
        const ctx = canvas.getContext('2d'); ctx.drawImage(img, 0, 0, width, height);
        resolve(canvas.toDataURL('image/jpeg', quality));
      };
      img.onerror = reject;
    };
    reader.onerror = reject;
  });
}

// ===== DATABASE =====
const DB = {
  get: (key) => { const data = localStorage.getItem(key); return data ? JSON.parse(data) : []; },
  set: (key, data) => localStorage.setItem(key, JSON.stringify(data)),
  getDemandas: () => DB.get('demandas_db'),
  setDemandas: (d) => DB.set('demandas_db', d),
  
  // NUMERAÇÃO INDEPENDENTE POR TIPO
  addDemanda: (item) => {
    const d = DB.getDemandas();
    item.id = d.length ? Math.max(...d.map(x => x.id)) + 1 : 1;
    const sameType = d.filter(x => x.tipo === item.tipo);
    const maxNum = sameType.reduce((max, x) => {
      const n = parseInt(x.num) || 0;
      return n > max ? n : max;
    }, 0);
    item.num = String(maxNum + 1).padStart(3, '0');
    item.created = new Date().toISOString();
    d.push(item); DB.setDemandas(d); return item;
  },
  
  updateDemanda: (id, data) => {
    const demandas = DB.getDemandas(); const idx = demandas.findIndex(x => x.id === id);
    if (idx > -1) { demandas[idx] = { ...demandas[idx], ...data, updated: new Date().toISOString() }; DB.setDemandas(demandas); return demandas[idx]; }
    return null;
  },
  getUsers: () => {
    const users = DB.get('users_db');
    if (users.length === 0) {
      const defaults = [
        { id: 1, name: 'Administrador', login: 'admin', pass: 'admin123', role: 'admin', active: true, photo: null, cargo: 'Administrador do Sistema' },
        { id: 2, name: 'Operador', login: 'operador', pass: 'op123', role: 'operator', active: true, photo: null, cargo: 'Operador de Demandas' },
        { id: 3, name: 'Analista', login: 'analista', pass: 'ana123', role: 'analyst', active: true, photo: null, cargo: 'Analista de Dados' }
      ];
      DB.set('users_db', defaults); return defaults;
    }
    return users;
  },
  setUsers: (u) => DB.set('users_db', u),
  addUser: (user) => {
    const users = DB.getUsers();
    user.id = users.length ? Math.max(...users.map(x => x.id)) + 1 : 1;
    user.active = true; user.photo = null; user.cargo = user.cargo || '';
    users.push(user); DB.setUsers(users); return user;
  },
  updateUser: (id, data) => {
    const users = DB.getUsers(); const idx = users.findIndex(u => u.id === id);
    if (idx > -1) { users[idx] = { ...users[idx], ...data }; DB.setUsers(users); return users[idx]; }
    return null;
  },
  deleteUser: (id) => DB.setUsers(DB.getUsers().filter(u => u.id !== id)),
  getDemandTypes: () => {
    const types = DB.get('demand_types');
    if (types.length === 0) { const defaults = ['Fiscalização de Trânsito', 'Apoio Operacional', 'Patrulhamento Escolar', 'Ocorrência Diversa', 'Manutenção']; DB.set('demand_types', defaults); return defaults; }
    return types;
  },
  setDemandTypes: (t) => DB.set('demand_types', t),
  addDemandType: (name) => { const types = DB.getDemandTypes(); if (!types.includes(name)) { types.push(name); DB.setDemandTypes(types); } return types; },
  updateDemandType: (old, newName) => { const types = DB.getDemandTypes(); const idx = types.indexOf(old); if (idx > -1) { types[idx] = newName; DB.setDemandTypes(types); } return types; },
  deleteDemandType: (name) => DB.setDemandTypes(DB.getDemandTypes().filter(t => t !== name))
};

