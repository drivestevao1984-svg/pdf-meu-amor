function setupTagInput(containerId, inputId, agentsArray) {
  const input = document.getElementById(inputId); if (!input) return;
  input.replaceWith(input.cloneNode(true)); const newInput = document.getElementById(inputId);
  newInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ',') { e.preventDefault(); const value = newInput.value.trim().toUpperCase(); if (value && !agentsArray.includes(value)) { agentsArray.push(value); renderTags(containerId, agentsArray, inputId); newInput.value = ''; newInput.focus(); } }
    if (e.key === 'Backspace' && !newInput.value && agentsArray.length > 0) { agentsArray.pop(); renderTags(containerId, agentsArray, inputId); }
  });
  document.getElementById(containerId).addEventListener('click', (e) => { if (e.target.id === containerId) newInput.focus(); });
}

function renderTags(containerId, arr, inputId) {
  const container = document.getElementById(containerId);
  container.innerHTML = arr.map((agent, idx) => `<span class="tag">${agent.toUpperCase()}<span class="tag-rm" data-idx="${idx}"><i class="fas fa-times"></i></span></span>`).join('');
  container.querySelectorAll('.tag-rm').forEach(btn => {
    btn.onclick = (e) => { e.stopPropagation(); const idx = parseInt(btn.dataset.idx);
      if (containerId === 'nd-agentes') ndAgentes.splice(idx, 1); else atAgentes.splice(idx, 1);
      renderTags(containerId, containerId === 'nd-agentes' ? ndAgentes : atAgentes, inputId);
    };
  });
}

