  document.getElementById('headerTitle').textContent = titles[page] || 'Dashboard';
  
  if (page === 'dashboard') renderDashboard();
  if (page === 'demandas-andamento') { renderAndamento(); updateAllBadges(); }
  if (page === 'demandas-finalizadas') renderFinalizadas();
  if (page === 'telefonico-andamento') { renderTelAndamento(); updateAllBadges(); }
  if (page === 'telefonico-finalizados') renderTelFinalizados();
  if (page === 'configuracoes') { renderUsers(); renderDemandTypes(); }
